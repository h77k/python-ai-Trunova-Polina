SELECT DISTINCT ?flower ?flowerLabel ?scientificName ?familyLabel ?distributionLabel ?usageLabel ?colorLabel ?image
WHERE {
  ?flower wdt:P31/wdt:P279* wd:Q506.  # Экземпляры или подклассы "цветок"
  OPTIONAL { ?flower wdt:P225 ?scientificName. }  # Научное название
  OPTIONAL { ?flower wdt:P171 ?family. }  # Семейство
  OPTIONAL { ?flower wdt:P1843 ?distribution. }  # Распространение
  OPTIONAL { ?flower wdt:P366 ?usage. }  # Использование
  OPTIONAL { ?flower wdt:P462 ?color. }  # Цвет цветка
  OPTIONAL { ?flower wdt:P18 ?image. }  # Изображение

  SERVICE wikibase:label { bd:serviceParam wikibase:language "ru". }
}
LIMIT 100
